# Azure OpenAI 配置示例
# 复制此文件为 .env 并填入你的 Azure OpenAI 凭证

# Azure OpenAI API 密钥
AZURE_OPENAI_API_KEY=your_api_key_here

# Azure OpenAI 端点 (例如: https://your-resource-name.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Azure OpenAI API 版本
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI 部署名称 (你在 Azure 上创建的模型部署名称)
# 常见的部署名称: gpt-4, gpt-35-turbo 等
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# ====================================
# 可选: 用于并发控制的参数
# ====================================

# 批处理大小 (控制并发请求数，根据你的 Azure 定额调整)
# 默认值: 5
# BATCH_SIZE=5

# 请求重试次数
# 默认值: 2
# MAX_RETRIES=2
